# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Force LF for Python and XML files
*.py text eol=lf
*.xml text eol=lf
*.csv text eol=lf
*.rst text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.scss text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.icc binary
