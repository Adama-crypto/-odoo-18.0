<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="website_catalog_template" name="Shop Catalog">
        <t t-call="website.layout">
            <div id="wrap" class="js_sale bg-light">
                <div class="container py-5">
                    <div class="row mb-5">
                        <div class="col-lg-8 mx-auto text-center">
                            <h1 class="display-4 fw-bold text-primary">Notre Catalogue Boutique</h1>
                            <p class="lead text-muted">Découvrez nos produits de qualité disponibles immédiatement.</p>
                        </div>
                    </div>
                    <div class="row">
                        <t t-if="not products">
                            <div class="col-12 text-center py-5">
                                <h3 class="text-muted">Aucun produit n'est disponible pour le moment.</h3>
                            </div>
                        </t>
                        <t t-foreach="products" t-as="product">
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card h-100 shadow-sm border-0">
                                    <div class="position-relative">
                                        <img t-att-src="'/web/image/product.template/%s/image_512' % product.id"
                                             class="card-img-top"
                                             t-att-alt="product.name"
                                             style="height: 250px; object-fit: cover;"/>
                                        <span class="badge bg-success position-absolute top-0 end-0 m-3 px-3 py-2">En Stock</span>
                                    </div>
                                    <div class="card-body d-flex flex-column justify-content-between p-4">
                                        <div>
                                            <h5 class="card-title fw-bold text-dark mb-2" t-esc="product.name"/>
                                            <p class="card-text text-muted small"
                                               t-esc="product.description or 'Aucune description disponible.'"/>
                                        </div>
                                        <div class="mt-4 d-flex justify-content-between align-items-center">
                                            <span class="h4 fw-bold text-primary mb-0">
                                                <t t-esc="product.list_price"
                                                   t-options='{"widget": "monetary", "display_currency": product.currency_id}'/> 
                                            </span>
                                            <span class="text-muted small">
                                                <t t-esc="int(product.qty_available)"/> dispo.
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>