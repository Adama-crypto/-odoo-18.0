<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Form View -->
    <record id="view_shop_product_form" model="ir.ui.view">
        <field name="name">shop.product.form</field>
        <field name="model">product.template</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <form string="Produit">
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name" string="Nom du produit"/>
                        <h1>
                            <field name="name" placeholder="Nom..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="list_price" string="Prix de vente"/>
                            <field name="categ_id" string="Catégorie"/>
                            <field name="is_published" string="Visible sur le site web"/>
                        </group>
                        <group>
                            <field name="qty_available" string="Quantité en stock" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Description du produit..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Product List View -->
    <record id="view_shop_product_tree" model="ir.ui.view">
        <field name="name">shop.product.tree</field>
        <field name="model">product.template</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <list string="Produits">
                <field name="name"/>
                <field name="categ_id"/>
                <field name="list_price"/>
                <field name="qty_available"/>
                <field name="is_published" string="Visible sur le site web"/>
            </list>
        </field>
    </record>

    <!-- Product Kanban View -->
    <record id="view_shop_product_kanban" model="ir.ui.view">
        <field name="name">shop.product.kanban</field>
        <field name="model">product.template</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="list_price"/>
                <field name="qty_available"/>
                <field name="is_published"/>
                <field name="image_1920"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('product.template', 'image_1920', record.id.raw_value)"
                                     alt="Produit" class="o_image_64_contain"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="name"/></strong>
                                <div>Prix : <field name="list_price"/></div>
                                <div>Stock : <field name="qty_available"/></div>
                                <div>
                                    <span t-if="record.is_published.raw_value" class="badge text-bg-success">Publié</span>
                                    <span t-else="" class="badge text-bg-secondary">Non publié</span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Product Search View -->
    <record id="view_shop_product_search" model="ir.ui.view">
        <field name="name">shop.product.search</field>
        <field name="model">product.template</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <search string="Rechercher un produit">
                <field name="name" string="Nom"/>
                <field name="categ_id" string="Catégorie"/>
                <filter string="Publié" name="published" domain="[('is_published', '=', True)]"/>
                <filter string="Non publié" name="not_published" domain="[('is_published', '=', False)]"/>
                <filter string="En stock" name="in_stock" domain="[('qty_available', '>', 0)]"/>
                <filter string="Rupture de stock" name="out_of_stock" domain="[('qty_available', '=', 0)]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Catégorie" name="group_categ" domain="[]" context="{'group_by': 'categ_id'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>