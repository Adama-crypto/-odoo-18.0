<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Standalone List View for Order Lines -->
    <record id="view_shop_order_line_tree" model="ir.ui.view">
        <field name="name">shop.order.line.tree</field>
        <field name="model">shop.order.line</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="product_id"/>
                <field name="product_uom_qty"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="price_unit" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="price_subtotal" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1" force_save="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_shop_order_form" model="ir.ui.view">
        <field name="name">shop.order.form</field>
        <field name="model">shop.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirmer" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_preparation" string="Préparer" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_shipped" string="Expédier" type="object" class="oe_highlight" invisible="state != 'preparation'"/>
                    <button name="action_delivered" string="Livrer" type="object" class="oe_highlight" invisible="state != 'shipped'"/>
                    <button name="action_cancel" string="Annuler" type="object" invisible="state in ('cancel', 'delivered')"/>
                    <button name="action_draft" string="Remettre en brouillon" type="object" invisible="state != 'cancel'"/>
                    <button name="%(shop_manager.action_report_shop_order)s" string="Imprimer Bon de commande" type="action" class="btn-secondary" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,preparation,shipped,delivered"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="date_order" readonly="state != 'draft'"/>
                            <field name="company_id" readonly="state != 'draft'" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="invoice_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lignes de commande">
                            <field name="line_ids" readonly="state != 'draft'" widget="one2many" context="{'default_order_id': id}"/>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_shop_order_tree" model="ir.ui.view">
        <field name="name">shop.order.tree</field>
        <field name="model">shop.order</field>
        <field name="arch" type="xml">
            <list string="Commandes">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date_order"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-warning="state in ('confirmed', 'preparation')"
                    decoration-success="state in ('shipped', 'delivered')"
                    decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_shop_order_kanban" model="ir.ui.view">
        <field name="name">shop.order.kanban</field>
        <field name="model">shop.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="amount_total"/>
                <field name="state"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_title">
                                <strong><field name="name"/></strong>
                            </div>
                            <div>
                                <field name="partner_id"/>
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <strong><field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/></strong>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Calendar View -->
    <record id="view_shop_order_calendar" model="ir.ui.view">
        <field name="name">shop.order.calendar</field>
        <field name="model">shop.order</field>
        <field name="arch" type="xml">
            <calendar string="Commandes" date_start="date_order" color="state">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="amount_total"/>
            </calendar>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_shop_order_search" model="ir.ui.view">
        <field name="name">shop.order.search</field>
        <field name="model">shop.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <filter string="Brouillon" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmée" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="En préparation" name="preparation" domain="[('state','=','preparation')]"/>
                <filter string="Expédiée" name="shipped" domain="[('state','=','shipped')]"/>
                <filter string="Livrée" name="delivered" domain="[('state','=','delivered')]"/>
                <filter string="Annulée" name="cancel" domain="[('state','=','cancel')]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Client" name="group_partner" domain="[]" context="{'group_by':'partner_id'}"/>
                    <filter string="Statut" name="group_state" domain="[]" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>