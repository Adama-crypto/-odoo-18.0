<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="report_shop_invoice_action" model="ir.actions.report">
        <field name="name">Facture Boutique</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">shop_manager.report_shop_invoice_template</field>
        <field name="report_file">shop_manager.report_shop_invoice_template</field>
        <field name="print_report_name">'Facture - %s' % (object.name)</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_shop_invoice_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Facture: <t t-esc="doc.name"/></h2>
                        <div class="row mt-4 mb-4">
                            <div class="col-6">
                                <strong>Client:</strong>
                                <div t-esc="doc.partner_id.name"/>
                                <div t-esc="doc.partner_id.contact_address"/>
                            </div>
                            <div class="col-6">
                                <strong>Date de Facturation:</strong>
                                <div t-esc="doc.invoice_date"/>
                            </div>
                        </div>
                        <table class="table table-sm o_main_table">
                            <thead>
                                <tr>
                                    <th>Produit</th>
                                    <th class="text-right">Quantité</th>
                                    <th class="text-right">Prix Unitaire</th>
                                    <th class="text-right">TVA</th>
                                    <th class="text-right">Sous-total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.invoice_line_ids" t-as="line">
                                    <tr>
                                        <td><span t-esc="line.product_id.name"/></td>
                                        <td class="text-right"><span t-esc="line.quantity"/></td>
                                        <td class="text-right"><span t-esc="line.price_unit"/></td>
                                        <td class="text-right"><span t-esc="', '.join(map(lambda t: t.name, line.tax_ids))"/></td>
                                        <td class="text-right"><span t-esc="line.price_subtotal"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <div class="row justify-content-end">
                            <div class="col-4">
                                <table class="table table-sm">
                                    <tr>
                                        <td>Sous-total</td>
                                        <td class="text-right"><span t-esc="doc.amount_untaxed"/> €</td>
                                    </tr>
                                    <tr>
                                        <td>TVA</td>
                                        <td class="text-right"><span t-esc="doc.amount_tax"/> €</td>
                                    </tr>
                                    <tr class="border-black o_total">
                                        <td><strong>Total</strong></td>
                                        <td class="text-right"><span t-esc="doc.amount_total"/> €</td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
