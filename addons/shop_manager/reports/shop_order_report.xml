<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_shop_order" model="ir.actions.report">
        <field name="name">Bon de Commande</field>
        <field name="model">shop.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">shop_manager.report_shop_order_template</field>
        <field name="report_file">shop_manager.report_shop_order_template</field>
        <field name="print_report_name">'Commande - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_shop_order"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_shop_order_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Bon de Commande: <t t-esc="doc.name"/></h2>
                        <div class="row mt-4 mb-4">
                            <div class="col-6">
                                <strong>Client:</strong>
                                <div t-esc="doc.partner_id.name"/>
                                <div t-esc="doc.partner_id.contact_address"/>
                            </div>
                            <div class="col-6">
                                <strong>Date de Commande:</strong>
                                <div t-esc="doc.date_order"/>
                            </div>
                        </div>
                        <table class="table table-sm o_main_table">
                            <thead>
                                <tr>
                                    <th>Produit</th>
                                    <th class="text-right">Quantité</th>
                                    <th class="text-right">Prix Unitaire</th>
                                    <th class="text-right">Sous-total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.line_ids" t-as="line">
                                    <tr>
                                        <td><span t-esc="line.product_id.name"/></td>
                                        <td class="text-right"><span t-esc="line.product_uom_qty"/></td>
                                        <td class="text-right"><span t-esc="line.price_unit"/></td>
                                        <td class="text-right"><span t-esc="line.price_subtotal"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <div class="row justify-content-end">
                            <div class="col-4">
                                <table class="table table-sm">
                                    <tr class="border-black o_total">
                                        <td><strong>Total</strong></td>
                                        <td class="text-right"><span t-esc="doc.amount_total"/> €</td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
