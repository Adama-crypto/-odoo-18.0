<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- IT Scan Alertes Wizard Form View -->
        <record id="it_scan_alertes_wizard_form_view" model="ir.ui.view">
            <field name="name">it.scan.alertes.wizard.form</field>
            <field name="model">it.scan.alertes.wizard</field>
            <field name="arch" type="xml">
                <form string="Résultat du scan d'alertes">
                    <sheet>
                        <group>
                            <field name="alerte_id"/>
                            <field name="message" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Équipements" invisible="not alerte_id or alerte_id.type != 'garantie'">
                                <field name="resultat_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="numero_serie"/>
                                        <field name="date_garantie"/>
                                        <field name="jours_garantie_restants"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Contrats" invisible="not alerte_id or alerte_id.type != 'contrat'">
                                <field name="resultat_contrat_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="fournisseur_id"/>
                                        <field name="date_fin"/>
                                        <field name="jours_restants"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button name="action_envoyer_notification" string="Envoyer notification" type="object" class="btn-primary"/>
                        <button string="Fermer" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
