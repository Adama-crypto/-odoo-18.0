<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- IT Reaffectation Wizard Form View -->
        <record id="it_reaffectation_wizard_form_view" model="ir.ui.view">
            <field name="name">it.reaffectation.wizard.form</field>
            <field name="model">it.reaffectation.wizard</field>
            <field name="arch" type="xml">
                <form string="Réaffecter l'équipement">
                    <sheet>
                        <group>
                            <group>
                                <field name="equipement_id"/>
                                <field name="ancien_employe_id"/>
                            </group>
                            <group>
                                <field name="nouvel_employe_id"/>
                                <field name="date_debut"/>
                            </group>
                        </group>
                        <group>
                            <field name="motif"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_confirmer" string="Confirmer" type="object" class="btn-primary"/>
                        <button string="Annuler" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
