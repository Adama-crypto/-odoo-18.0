<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- IT Technicien Group -->
        <record id="group_it_technicien" model="res.groups">
            <field name="name">IT Technicien</field>
            <field name="category_id" ref="base.module_category_tools"/>
            <field name="comment">Technicien IT : lecture + création d'interventions uniquement</field>
        </record>

        <!-- IT Manager Group -->
        <record id="group_it_manager" model="res.groups">
            <field name="name">IT Manager</field>
            <field name="category_id" ref="base.module_category_tools"/>
            <field name="comment">IT Manager : accès complet à tout le module</field>
            <field name="implied_ids" eval="[(4, ref('group_it_technicien'))]"/>
        </record>

        <!-- Record Rules for IT Technicien -->
        <!-- Can only see interventions they created -->
        <record id="it_intervention_technicien_rule" model="ir.rule">
            <field name="name">IT Intervention: Technicien can only see own interventions</field>
            <field name="model_id" ref="model_it_intervention"/>
            <field name="domain_force">[('technicien_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_it_technicien'))]"/>
        </record>

        <!-- Record Rules for IT Manager -->
        <!-- No restrictions for manager -->
    </data>
</odoo>
