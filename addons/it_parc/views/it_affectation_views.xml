<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- IT Affectation Tree View -->
        <record id="it_affectation_tree_view" model="ir.ui.view">
            <field name="name">it.affectation.list</field>
            <field name="model">it.affectation</field>
            <field name="arch" type="xml">
                <list string="Affectations">
                    <field name="equipement_id"/>
                    <field name="employe_id"/>
                    <field name="date_debut"/>
                    <field name="date_fin"/>
                    <field name="active" decoration-success="active==True"/>
                </list>
            </field>
        </record>

        <!-- IT Affectation Form View -->
        <record id="it_affectation_form_view" model="ir.ui.view">
            <field name="name">it.affectation.form</field>
            <field name="model">it.affectation</field>
            <field name="arch" type="xml">
                <form string="Affectation">
                    <sheet>
                        <group>
                            <group>
                                <field name="equipement_id" required="1"/>
                                <field name="employe_id" required="1"/>
                            </group>
                            <group>
                                <field name="date_debut" required="1"/>
                                <field name="date_fin"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <group>
                            <field name="motif"/>
                            <field name="notes"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- IT Affectation Search View -->
        <record id="it_affectation_search_view" model="ir.ui.view">
            <field name="name">it.affectation.search</field>
            <field name="model">it.affectation</field>
            <field name="arch" type="xml">
                <search string="Recherche affectation">
                    <field name="equipement_id"/>
                    <field name="employe_id"/>
                    <field name="date_debut"/>
                    <field name="active"/>
                    <filter string="Actives" name="active" domain="[('active','=',True)]"/>
                    <filter string="Inactives" name="inactive" domain="[('active','=',False)]"/>
                    <group expand="0" string="Group by">
                        <filter string="Équipement" name="group_equipement" domain="[]" context="{'group_by':'equipement_id'}"/>
                        <filter string="Employé" name="group_employe" domain="[]" context="{'group_by':'employe_id'}"/>
                        <filter string="Site" name="group_site" domain="[]" context="{'group_by':'site_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- IT Affectation Action -->
        <record id="it_affectation_action" model="ir.actions.act_window">
            <field name="name">Affectations</field>
            <field name="res_model">it.affectation</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
