<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron task for automatic alert scanning -->
        <record id="ir_cron_scan_alertes" model="ir.cron">
            <field name="name">IT Parc: Scan automatique des alertes</field>
            <field name="model_id" ref="model_it_alerte"/>
            <field name="state">code</field>
            <field name="code">model.cron_scan_alertes()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
