<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estate_room_type_action" model="ir.actions.act_window">
        <field name="name">Types de pièces</field>
        <field name="res_model">estate.room.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="estate_room_type_view_list" model="ir.ui.view">
        <field name="name">estate.room.type.list</field>
        <field name="model">estate.room.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="estate_room_type_view_form" model="ir.ui.view">
        <field name="name">estate.room.type.form</field>
        <field name="model">estate.room.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Pièces">
                            <field name="room_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="property_id"/>
                                    <field name="area"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
