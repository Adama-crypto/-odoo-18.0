<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estate_room_action" model="ir.actions.act_window">
        <field name="name">Pièces</field>
        <field name="res_model">estate.room</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="estate_room_view_list" model="ir.ui.view">
        <field name="name">estate.room.list</field>
        <field name="model">estate.room</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="room_type_id"/>
                <field name="property_id"/>
                <field name="area"/>
            </list>
        </field>
    </record>

    <record id="estate_room_view_form" model="ir.ui.view">
        <field name="name">estate.room.form</field>
        <field name="model">estate.room</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="room_type_id"/>
                        <field name="property_id"/>
                        <field name="area"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
