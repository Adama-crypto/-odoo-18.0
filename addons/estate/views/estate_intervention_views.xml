<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estate_intervention_action" model="ir.actions.act_window">
        <field name="name">Interventions</field>
        <field name="res_model">estate.intervention</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="estate_intervention_view_list" model="ir.ui.view">
        <field name="name">estate.intervention.list</field>
        <field name="model">estate.intervention</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="type"/>
                <field name="property_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="estate_intervention_view_form" model="ir.ui.view">
        <field name="name">estate.intervention.form</field>
        <field name="model">estate.intervention</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="planned,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="property_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
