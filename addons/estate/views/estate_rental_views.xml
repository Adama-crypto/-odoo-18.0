<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estate_rental_action" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">estate.rental</field>
        <field name="view_mode">list,kanban,form,calendar,graph</field>
    </record>

    <record id="estate_rental_view_search" model="ir.ui.view">
        <field name="name">estate.rental.search</field>
        <field name="model">estate.rental</field>
        <field name="arch" type="xml">
            <search>
                <field name="tenant_id"/>
                <field name="property_id"/>
                <filter string="En cours" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <group expand="1" string="Group By">
                    <filter string="Locataire" name="tenant" context="{'group_by':'tenant_id'}"/>
                    <filter string="Statut" name="state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="estate_rental_view_list" model="ir.ui.view">
        <field name="name">estate.rental.list</field>
        <field name="model">estate.rental</field>
        <field name="arch" type="xml">
            <list>
                <field name="tenant_id"/>
                <field name="property_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="duration"/>
                <field name="rent"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="estate_rental_view_form" model="ir.ui.view">
        <field name="name">estate.rental.form</field>
        <field name="model">estate.rental</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,validated,in_progress,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="tenant_id"/>
                            <field name="property_id"/>
                            <field name="reservation_date"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="duration"/>
                        </group>
                        <group>
                            <field name="payment_frequency"/>
                            <field name="rent"/>
                            <field name="inventory_status"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_rental_view_kanban" model="ir.ui.view">
        <field name="name">estate.rental.kanban</field>
        <field name="model">estate.rental</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="tenant_id"/>
                <field name="property_id"/>
                <field name="rent"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div>
                                <strong><field name="property_id"/></strong>
                            </div>
                            <div>
                                Locataire: <field name="tenant_id"/>
                            </div>
                            <div>
                                Loyer: <field name="rent"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="estate_rental_view_calendar" model="ir.ui.view">
        <field name="name">estate.rental.calendar</field>
        <field name="model">estate.rental</field>
        <field name="arch" type="xml">
            <calendar string="Locations" date_start="start_date" date_stop="end_date" color="tenant_id">
                <field name="property_id"/>
                <field name="tenant_id"/>
            </calendar>
        </field>
    </record>

    <record id="estate_rental_view_graph" model="ir.ui.view">
        <field name="name">estate.rental.graph</field>
        <field name="model">estate.rental</field>
        <field name="arch" type="xml">
            <graph string="Loyer par propriété" type="bar">
                <field name="property_id" type="row"/>
                <field name="rent" type="measure"/>
            </graph>
        </field>
    </record>
</odoo>
